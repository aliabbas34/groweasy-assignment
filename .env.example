# ── Backend ───────────────────────────────────────────────
# Get a free API key (no credit card) from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI-compatible base URL for NVIDIA NIM
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model id (verify exact string on build.nvidia.com; fall back to another NIM model if unavailable)
LLM_MODEL=mistralai/mistral-medium-3.5-128b

# Rows sent to the LLM per batch. Smaller = more frequent progress updates (the free NIM
# endpoint is ~15 tok/s, so large batches take minutes before the first update). 4-8 is a good range.
BATCH_SIZE=6

# Max tokens per batch reply (raise for larger batches to avoid truncation)
LLM_MAX_TOKENS=8192

# Optional reasoning budget for reasoning-capable models (e.g. low | high). Leave unset to disable.
# LLM_REASONING_EFFORT=low

# Express port
PORT=4000

# Allowed CORS origin (the deployed frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────
# Base URL of the backend API (set to the deployed backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:4000
